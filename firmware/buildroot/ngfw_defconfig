#
# NGFW Buildroot Configuration
# Build system for embedded NGFW firmware
#

# Buildroot version
BR2_VERSION="2024.02.1"

# Architecture
BR2_arm64=y
BR2_ARCH="aarch64"
BR2_TARGET_ARCH="arm64"

# System
BR2_TARGET_GENERIC_HOSTNAME="ngfw"
BR2_TARGET_GENERIC_DOMAIN="localdomain"
BR2_TARGET_GENERIC_ROOTFS="ext4"
BR2_TARGET_GENERIC_RECMAKE="y"
BR2_TARGET_GENERIC_PASSWD_HASH="sha512"
BR2_TARGET_GENERIC_PASSWD_METHOD="shadow"

# Build options
BR2_OPTIMIZE_2=y
BR2_OPTIMIZE_3=y
BR2_TARGET_LITTLE_ENDIAN=y
BR2_TARGET_GENERIC_UTS_RELEASE="6.1-ngfw"

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_VERSION="6.1.80"
BR2_LINUX_KERNEL_DEFCONFIG="ngfw"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES=""

# Linux headers
BR2_KERNEL_HEADERS_VERSION=y
BR2_DEFAULT_KERNEL_HEADERS="6.1.80"

# Init system
BR2_INIT_SYSTEMD=y
BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE="115200"

# Toolchain
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_Linaro_AArch64=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_PREFIX="aarch64-linux-gnu"
BR2_TOOLCHAIN_EXTERNAL_GCC_13=y
BR2_TOOLCHAIN_EXTERNAL_UCLIBC=n

# Firmware size
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"

# System packages
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_CONFIG="package/busybox/busybox-minimal.config"

# Network
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_IPSET=y
BR2_PACKAGE_ETHTOOL=y
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_IFUPLOAD=y

# System tools
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UBUS=y
BR2_PACKAGE_JSON_C=y

# NGFW Application
BR2_PACKAGE_NGFW_APP=y
BR2_PACKAGE_NGFW_APP_PATH="/mnt/public_home/work/research/ngfw"

# SSL/TLS
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_OPENSSL_BIN=y
BR2_PACKAGE_OPENSSL_ENGINES=y
BR2_PACKAGE_CURL=y

# SNMP
BR2_PACKAGE_NETSNMP=y
BR2_PACKAGE_NETSNMP_UTILITIES=y

# Logging
BR2_PACKAGE_RSYSLOG=y
BR2_PACKAGE_RSYSLOG_UDP=y
BR2_PACKAGE_RSYSLOG_TCP=y

# Compression
BR2_PACKAGE_ZLIB=y
BR2_PACKAGE_LZ4=y

# Development
BR2_PACKAGE_GDB=n
BR2_PACKAGE_STRACE=n

# Runtime
BR2_TARGET_GENERIC_ROOTFS_OVERLAY=""
BR2_ROOTFS_OVERLAY="board/ngfw/overlay"

# Output
BR2_DL_DIR="/mnt/public_home/work/research/ngfw/firmware/buildroot/dl"
BR2_BUILD_DIR="/mnt/public_home/work/research/ngfw/firmware/buildroot/build"
BR2_HOST_DIR="/mnt/public_home/work/research/ngfw/firmware/buildroot/host"

# Legal
BR2_COPY_GPLV3=y
BR2_LICENSE_FILES="COPYING" 

# Binary format
BR2_BINUTILS_VERSION_2_41_X=y
BR2_GCC_VERSION_13_X=y
BR2_BINUTILS_SUPPORTS_AVE=y