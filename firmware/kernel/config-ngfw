#
# NGFW Linux Kernel Configuration
# Next-Generation Firewall Kernel 6.x
#

CONFIG_LOCALVERSION="-ngfw-v2.0.0"
CONFIG_LOCALVERSION_AUTO=y
CONFIG_DEFAULT_HOSTNAME="ngfw"
CONFIG_DOMAINNAME="localdomain"

#
# Processor type and features
#
CONFIG_ARM64=y
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARCH_VIRT=y
CONFIG_SCHED_MC=y
CONFIG_NR_CPUS=8

#
# Kernel features
#
CONFIG_HAVE_KERNEL=y
CONFIG_HAVE_ARCH_BINARY_RELO=y
CONFIG_KEXEC=y
CONFIG_KEXEC_CORE=y
CONFIG_CRASH_DUMP=y
CONFIG_XEN_DOM0=y
CONFIG_ACPI=y

#
# Memory and performance
#
CONFIG_HUGETLB_PAGE=y
CONFIG_MEMCG=y
CONFIG_SLUB=y
CONFIG_SLAB=y
CONFIG_HAVE_ARCH_SOFT_DIRTY=y

#
# Networking - NGFW Core
#
CONFIG_NET=y
CONFIG_NET_IPVTI=y
CONFIG_NET_UDP_TUNNEL=y
CONFIG_NET_FOU=y
CONFIG_NET_IPVTI=y

# Connection Tracking (conntrack) - Essential for Firewall
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_CONNTRACK_ZONES=y
CONFIG_NF_CONNTRACK_PROCFS=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_NF_CONNTRACK_TIMEOUT=y
CONFIG_NF_CONNTRACK_TIMESTAMP=y
CONFIG_NF_CONNTRACK_LABELS=y
CONFIG_NF_LOG_IPV4=y
CONFIG_NF_LOG_IPV6=y

# Netfilter tables
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y

# Filter table
CONFIG_NF_FILTER=y
CONFIG_NF_FILTER_NETDEV=y

# NAT
CONFIG_NF_NAT=y
CONFIG_NF_NAT_IPV4=y
CONFIG_NF_NAT_IPV6=y

# Connection tracking helpers
CONFIG_NF_CONNTRACK_H323=y
CONFIG_NF_CONNTRACK_IRC=y
CONFIG_NF_CONNTRACK_FTP=y
CONFIG_NF_CONNTRACK_SIP=y
CONFIG_NF_CONNTRACK_SNMP=y
CONFIG_NF_CONNTRACK_PPTP=y

# IP set support for firewall rules
CONFIG_IP_SET=y
CONFIG_IP_SET_BITMAP_IP=y
CONFIG_IP_SET_BITMAP_IPMAC=y
CONFIG_IP_SET_BITMAP_PORT=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_IPPORT=y
CONFIG_IP_SET_HASH_IPPORTIP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_NETPORT=y
CONFIG_IP_SET_HASH_NETNET=y
CONFIG_IP_SET_LIST_SET=y

# Layer 7 filtering
CONFIG_NF_CONNTRACK_L7PROC=y
CONFIG_NETFILTER_XT_LAYER7=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y
CONFIG_NETFILTER_XT_TARGET_CONNMARK=y
CONFIG_NETFILTER_XT_TARGET_MARK=y

# IPsec
CONFIG_XFRM=y
CONFIG_XFRM_USER=y
CONFIG_XFRM_INTERFACE=y
CONFIG_XFRM_SUB_POLICY=y
CONFIG_XFRM_MIGRATE=y
CONFIG_XFRM_STATISTICS=y
CONFIG_XFRM_ESP=y
CONFIG_XFRM_AH=y

# IP Virtual Server (Load Balancing)
CONFIG_IP_VS=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y
CONFIG_IP_VS_PROTO_ESP=y
CONFIG_IP_VS_PROTO_AH=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_LC=y
CONFIG_IP_VS_WLC=y
CONFIG_IP_VS_FO=y
CONFIG_IP_VS_OVF=y

# QoS / Traffic Control
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_CBQ=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_SCH_HFSC=y
CONFIG_NET_SCH_PRIO=y
CONFIG_NET_SCH_MQPRIO=y
CONFIG_NET_SCH_SFQ=y
CONFIG_NET_SCH_TBF=y
CONFIG_NET_SCH_TEQL=y
CONFIG_NET_SCH_CBS=y
CONFIG_NET_SCH_ETF=y
CONFIG_NET_SCH_PLUG=y

# Packet mirroring (port mirroring for monitoring)
CONFIG_NET_ACT_MIRRED=y
CONFIG_NET_ACT_TUNNEL_KEY=y

#
# Cryptographic API
#
CONFIG_CRYPTO=y
CONFIG_CRYPTO_CAMELLIA=y
CONFIG_CRYPTO_CAMELLIA_SPARC64=y
CONFIG_CRYPTO_CAMELLIA_SSE2=y
CONFIG_CRYPTO_CAST5=y
CONFIG_CRYPTO_CAST6=y
CONFIG_CRYPTO_DES=y
CONFIG_CRYPTO_TWOFISH=y

# AES-NI hardware acceleration
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_ARM64=y
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
CONFIG_CRYPTO_AES_ARM64_CE_CCM=y

# GCM/CCM
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_CCM=y

# SHA
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_SHA1_ARM64_CE=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA2=y
CONFIG_CRYPTO_SHA256_ARM64=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_SHA512_ARM64=y

# Hardware Random Number Generator
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_GEODE=y
CONFIG_HW_RANDOM_VIA=y
CONFIG_HW_RANDOM_CAVIUM=y

# Crypto backend - Arm TrustZone
CONFIG_CRYPTO_DEV_ATMEL_I2C=y
CONFIG_CRYPTO_DEV_ATMEL_SHA204A=y
CONFIG_CRYPTO_DEV_CCP=y

#
# Network interfaces
#
CONFIG_ETHERNET=y
CONFIG_MDIO=y
CONFIG_NET_VENDOR_ALL=y

# Intel network drivers
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IGBVF=y
CONFIG_IXGBE=y
CONFIG_IXGBEVF=y
CONFIG_I40E=y
CONFIG_I40EVF=y
CONFIG_ICE=y

# Broadcom
CONFIG_B44=y
CONFIG_BCMGENET=y
CONFIG_TSI108_BRIDGE=y

# Marvell
CONFIG_MV643XX_ETH=y
CONFIG_MVNETA=y
CONFIG_MVPP2=y

# Mellanox
CONFIG_MELLANOX_PLATFORM=y
CONFIG_MLX4_EN=y
CONFIG_MLX5_CORE=y

# Realtek
CONFIG_R8169=y
CONFIG_R8125=y

# Virtual network
CONFIG_VETH=y
CONFIG_TUN=y
CONFIG_VIRTIO_NET=y
CONFIG_MACVLAN=y
CONFIG_MACVTAP=y

#
# DPDK Support
#
CONFIG_RTE_EAL_IGB_UIO=y
CONFIG_RTE_EAL_VFIO=y
CONFIG_RTE_KNI=y
CONFIG_RTE_PMD_PCAP=y

#
# VLAN
#
CONFIG_VLAN_8021Q=y
CONFIG_VLAN_8021Q_GVRP=y

# Bridge
CONFIG_BRIDGE=y
CONFIG_BRIDGE_IGMP_SNOOPING=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_STP=y

#
# Bypass / Packet acceleration
#
CONFIG_NF_NAT_DSIPROXY=y
CONFIG_TUNNEL_BYPASS=y
CONFIG_BPF_JIT=y

# XDP (Express Data Path)
CONFIG_XDP_SOCKETS=y
CONFIG_XDP_SOCK_DIAG=y

# AF_XDP
CONFIG_AF_XDP=y

#
# Memory management
#
CONFIG_MEMORY_BALLOON=y
CONFIG_SPARSEMEM=y
CONFIG_SPARSEMEM_VMEMMAP=y

# Huge pages for DPDK
CONFIG_HUGETLBFS=y
CONFIG_HUGE_MTLHOME=y

#
# Filesystems
#
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_STAT_FS=y
CONFIG_F2FS_FS_XATTR=y
CONFIG_F2FS_FS_POSIX_ACL=y
CONFIG_F2FS_FS_SECURITY=y

# Overlay filesystem
CONFIG_OVERLAY_FS=y

# Network filesystems
CONFIG_NFS_V4=y
CONFIG_NFS_V4_1=y
CONFIG_NFS_V4_2=y
CONFIG_CIFS=y
CONFIG_CIFS_UPCALL=y

# Compression
CONFIG_ZRAM=y
CONFIG_ZSWAP=y

#
# proc / sysfs
#
CONFIG_PROC_SYSCTL=y
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_MEMCG_SWAP=y

#
# Debugging
#
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_BUGVERBOSE=y
CONFIG_FRAME_POINTER=y
CONFIG_KALLSYMS=y
CONFIG_DEBUG_FS=y
CONFIG_TRACING=y
CONFIG_EVENT_TRACING=y
CONFIG_FUNCTION_TRACING=y

# Logging
CONFIG_PRINTK=y
CONFIG_PRINTK_NMI=y
CONFIG_LOG_BUF_SHIFT=20
CONFIG_LOG_CPU_MAX_BUF_SHIFT=15
CONFIG_HAVE_DYNAMIC_FTRACE=y

# Crash dump
CONFIG_CRASH_DUMP=y
CONFIG_KEXEC_CORE=y
CONFIG_PROC_VMCORE=y

#
# Boot
#
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_ARM_STUB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_LOAD_UBOOT=y
CONFIG_OF=y

# Init
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_INITRAMFS_COMPRESSION=y
CONFIG_INITRAMFS_COMPRESSION_LZ4=y

# Cgroup
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Seccomp
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# AppArmor
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOT_PARAMETER_VALUE=y

# SELinux (optional)
# CONFIG_SECURITY_SELINUX=y

# Integrity
CONFIG_IMA=y
CONFIG_IMA_NG=y

#
# Hardware monitoring
#
CONFIG_HWMON=y
CONFIG_SENSORS_ADT7462=y
CONFIG_SENSORS_ADT7470=y
CONFIG_SENSORS_LM75=y
CONFIG_SENSORS_LM85=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_DWAPB=y

# Watchdog
CONFIG_WATCHDOG=y
CONFIG_SOFT_WATCHDOG=y
CONFIG_WATCHDOG_NOWAYOUT=y

# RTC
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_CMOS=y
CONFIG_RTC_DRV_EM3027=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# LED
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_TRIGGERS=y

#
# Performance Monitoring
#
CONFIG_PERCPU_STATS=y
CONFIG_TRACEPOINTS=y
CONFIG_HAVE_PERF_EVENTS=y
CONFIG_PERF_EVENTS=y

#
# Kernel samepage merging
#
CONFIG_KSM=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=4096

# Transparent Hugepages
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y

#
# NGFW Custom Settings
#
CONFIG_NGFW_QOS=y
CONFIG_NGFW_IPS=y
CONFIG_NGFW_URLFILTER=y
CONFIG_NGFW_ANTIVIRUS=n
CONFIG_NGFW_DPDK=y

# Enable packet forwarding
CONFIG_IP_FORWARD=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_MROUTE=y

# TCP/IP tuning
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_MD5SIG=y
CONFIG_DEFAULT_BBR=y